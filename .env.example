# ── Required ─────────────────────────────────────────────────────────────────

# Napster Omniagent API Key (from your Napster dashboard)
NAPSTER_API_KEY=your_napster_api_key_here

# Internal secret — authenticates Napster tool webhook calls back to this server
# Set this to any random string (e.g. openssl rand -hex 16)
INTERNAL_API_SECRET=change_me_to_a_random_string

# ── Required for tool webhooks ────────────────────────────────────────────────
# Public URL where Napster can POST tool calls (capture_lead, check_slots, book_appointment)
# For local testing: run `ngrok http 3001` and paste the https URL here
# For production: your deployed backend URL (e.g. https://localdesk.up.railway.app)
# Leave blank to run in UI-only mode (agent connects but tools won't fire)
BACKEND_PUBLIC_URL=

# ── Optional: Twilio SMS notifications ───────────────────────────────────────
# Leave blank to skip SMS — the app works without it
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
BUSINESS_OWNER_PHONE=

# ── Internal (do not change) ──────────────────────────────────────────────────
PORT=3001

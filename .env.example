# Napster Omniagent API Key (from your Napster dashboard)
NAPSTER_API_KEY=your_napster_api_key_here

# Internal API secret — used to authenticate tool webhook calls from Napster back to this server
INTERNAL_API_SECRET=change_me_to_a_random_string

# Port the backend runs on (inside Docker)
PORT=3001

# Optional: Twilio SMS notifications (leave blank to skip SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
BUSINESS_OWNER_PHONE=
